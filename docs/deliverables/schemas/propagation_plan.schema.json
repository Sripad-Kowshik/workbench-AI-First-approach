{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "propagation_plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "task_id",
    "issue_id",
    "created_at",
    "created_by",
    "workspace",
    "confidence",
    "blockers",
    "validation",
    "completed_target",
    "remaining_targets",
    "ordering_rationale"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "artifact_type": {
      "const": "propagation_plan"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "base_branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "hotfix_branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "base_sha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$"
    },
    "hotfix_sha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$"
    },
    "source_shas": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{40}$"
      },
      "minItems": 0
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "blockers": {
      "type": "array"
    },
    "validation": {
      "type": [
        "object",
        "null"
      ]
    },
    "completed_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "package_ref"
      ],
      "properties": {
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "package_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "remaining_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "branch",
          "status",
          "task_id"
        ],
        "properties": {
          "branch": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "done",
              "skipped"
            ]
          },
          "task_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "ordering_rationale": {
      "type": "string",
      "minLength": 1
    }
  }
}
