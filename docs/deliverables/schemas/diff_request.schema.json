{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "diff_request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "task_id",
    "issue_id",
    "created_at",
    "created_by",
    "workspace",
    "confidence",
    "blockers",
    "validation",
    "test_gate",
    "applied_commits",
    "exclude_globs",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "artifact_type": {
      "const": "diff_request"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "base_branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "hotfix_branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "base_sha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$"
    },
    "hotfix_sha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$"
    },
    "source_shas": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{40}$"
      },
      "minItems": 0
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "blockers": {
      "type": "array"
    },
    "validation": {
      "type": [
        "object",
        "null"
      ]
    },
    "test_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "exit_code",
        "log_ref"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "exit_code": {
          "type": "integer",
          "const": 0
        },
        "log_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "applied_commits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sha",
          "applied_as",
          "method",
          "conflicts"
        ],
        "properties": {
          "sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "applied_as": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "method": {
            "type": "string",
            "enum": [
              "cherry-pick",
              "merge",
              "squash",
              "patch"
            ]
          },
          "conflicts": {
            "type": "boolean"
          }
        }
      }
    },
    "exclude_globs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
