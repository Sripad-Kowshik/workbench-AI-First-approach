{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "escalation_request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "task_id",
    "issue_id",
    "created_at",
    "created_by",
    "workspace",
    "confidence",
    "blockers",
    "validation",
    "phase",
    "trigger",
    "summary",
    "evidence",
    "options",
    "response"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "artifact_type": {
      "const": "escalation_request"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "base_branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "hotfix_branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "base_sha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$"
    },
    "hotfix_sha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$"
    },
    "source_shas": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{40}$"
      },
      "minItems": 0
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "blockers": {
      "type": "array"
    },
    "validation": {
      "type": [
        "object",
        "null"
      ]
    },
    "phase": {
      "type": "string",
      "enum": [
        "chf_execute",
        "diff",
        "pack",
        "finalize",
        "orchestrator"
      ]
    },
    "trigger": {
      "type": "string",
      "enum": [
        "DIRTY_WORKTREE",
        "BASE_BRANCH_UNRESOLVED",
        "CHERRY_PICK_CONFLICT",
        "TEST_COMMAND_UNKNOWN",
        "TEST_GATE_FAILED",
        "DEPENDENCY_COMMIT_MISSING",
        "ANCESTRY_AMBIGUOUS",
        "MANIFEST_INCOMPLETE",
        "MANIFEST_INTEGRITY_MISMATCH",
        "DEST_LAYOUT_AMBIGUOUS",
        "PERMISSIONS_AMBIGUOUS",
        "WORKSPACE_CONFLICT",
        "SCHEMA_VALIDATION_FAILED",
        "LOW_CONFIDENCE",
        "STEERING_CONTRADICTION"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "label",
          "consequence",
          "recommended"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[A-Z]$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "consequence": {
            "type": "string",
            "minLength": 1
          },
          "recommended": {
            "type": "boolean"
          }
        }
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "recommended": {
                "const": true
              }
            },
            "required": [
              "recommended"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "response": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
